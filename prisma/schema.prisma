generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id                String                @id @default(uuid()) @db.Uuid
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  age               Int
  gender            String?
  state             String
  district          String?
  occupation        String
  annualIncome      String?               @map("annual_income")
  caste             String?
  disability        Boolean               @default(false)
  landHolding       String?               @map("land_holding")
  preferredLanguage String                @default("en") @map("preferred_language")
  familySize        Int?                  @map("family_size")
  savedSchemes      SavedScheme[]
  applications      ApplicationTracking[]

  @@map("user_profiles")
}

model SavedScheme {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  schemeId  String      @map("scheme_id")
  savedAt   DateTime    @default(now()) @map("saved_at") @db.Timestamptz(6)
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_schemes")
}

model ApplicationTracking {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  schemeId  String      @map("scheme_id")
  status    String      @default("not_started")
  notes     String?
  updatedAt DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("application_tracking")
}
